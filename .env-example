# Copy this file to `.env` and fill in the values you need.
# `.env` is ignored by git.

# Featherless LLM API key used by backend/translation_agent.py.
# Leave empty to use the deterministic mock fallback.
FEATHERLESS_API_KEY=

# Optional Featherless overrides. Defaults shown here match the code.
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# Optional URL for a separately running Data-Engineer service.
# Leave empty to call backend.data_engineer in-process.
# Example: http://localhost:8002
DATA_ENGINEER_URL=

# Sybilion API token reserved for the Block 4 forecast client.
# Not used by the current committed Python code yet.
SYBILION_API_TOKEN=
